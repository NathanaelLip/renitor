---
import Layout from "../layouts/Layout.astro";

if (Astro.locals.user) {
    return Astro.redirect("/dashboard");
}
---

<Layout title="Login">
    <div class="flex items-center justify-center min-h-screen bg-neutral-800">
        <form
            action="/api/login"
            method="POST"
            class="bg-white p-8 shadow-md rounded-lg w-96"
        >
            <h1 class="text-2xl font-bold mb-6 text-center">Renitor Login</h1>
            <div class="space-y-4">
                <input
                    name="username"
                    type="text"
                    placeholder="Username"
                    class="w-full border p-2"
                    required
                />
                <input
                    name="password"
                    type="password"
                    placeholder="Password"
                    class="w-full border p-2"
                    required
                />
                <button
                    type="submit"
                    class="w-full bg-amber-600 text-white py-2 font-bold hover:bg-amber-700"
                >
                    Login
                </button>
            </div>
        </form>
    </div>
</Layout>
